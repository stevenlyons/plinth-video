{
  "name": "@wirevice/plinth-js",
  "version": "0.6.1",
  "description": "WebAssembly-powered Video telemetry SDK for the web — tracks playback metrics (VST, rebuffer time, played time) and reports beacons via HTTP",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "wasm"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stevenlyons/plinth-telemetry.git",
    "directory": "packages/web/plinth-js"
  },
  "keywords": [
    "video",
    "qoe",
    "telemetry",
    "analytics",
    "playback",
    "metrics",
    "wasm",
    "webassembly"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:wasm": "cd ../../../crates/plinth-core && PATH=\"$HOME/.cargo/bin:$PATH\" wasm-pack build --target web --out-dir ../../packages/web/plinth-js/wasm",
    "test": "node --test --import tsx/esm tests/*.test.ts"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^22.0.0"
  }
}
